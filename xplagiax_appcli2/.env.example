# ════════════════════════════════════════════════════════════════════════════
#  xplagiax_appcli2 — plantilla de variables de entorno
#
#  Copia este archivo como `.env` en esta misma carpeta (xplagiax_appcli2/)
#  y rellena los valores. settings/config.py lo carga automáticamente al
#  arrancar (load_dotenv). Las variables de entorno reales del sistema o de
#  docker (-e / --env-file) siempre tienen prioridad sobre este archivo.
#
#  IMPORTANTE (Docker): .env está excluido por .dockerignore — NO viaja dentro
#  de la imagen. En Docker pásalo en el run/compose:
#      docker run --env-file .env ...
#  o en docker-compose:  env_file: [.env]
# ════════════════════════════════════════════════════════════════════════════

# ── Flask ────────────────────────────────────────────────────────────────────
# 'production' activa cookies Secure y desactiva db.create_all()
FLASK_ENV=production
# Clave ÚNICA y estable: firma las cookies de sesión y los tokens de
# confirmación/reset. Genera una con:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Base de datos ────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://usuario:password@host/xplagiax_db

# ── Google OAuth (login de usuarios) ─────────────────────────────────────────
# Crear en https://console.cloud.google.com/apis/credentials
#   Tipo: "OAuth client ID" → "Web application"
#   Authorized redirect URI (EXACTA, con la 'x' final):
#     https://app.xplagiax.ca/auth_bp/google/callbackx
#   (para desarrollo añade también: http://127.0.0.1:5003/auth_bp/google/callbackx)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opcional: fuerza una redirect URI concreta; si se omite se deriva del host real.
# GOOGLE_REDIRECT_URI=https://app.xplagiax.ca/auth_bp/google/callbackx

# ── Microsoft OAuth (login de usuarios) ──────────────────────────────────────
# Crear en https://portal.azure.com → App registrations
#   Redirect URI (Web): https://app.xplagiax.ca/auth_bp/microsoft/callback
#   (para desarrollo añade también: http://127.0.0.1:5003/auth_bp/microsoft/callback)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=https://app.xplagiax.ca/auth_bp/microsoft/callback

# ── Seguridad OAuth ──────────────────────────────────────────────────────────
# Poner en false cuando el login OAuth quede estable, para reactivar la
# validación anti-CSRF del parámetro state.
OAUTH_RELAX_STATE=true

# ── Redis (rate limiting / celery) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/14

# ── Email ────────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.ionos.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
